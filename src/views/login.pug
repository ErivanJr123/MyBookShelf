extends layout

block content
  .auth-wrapper(style="max-width: 400px; margin: 50px auto; padding: 25px; border: 1px solid #ddd; border-radius: 8px; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.05);")
    .auth-card
      h2(style="text-align: center; margin-bottom: 5px; color: #2c3e50;") Entrar no MyBookShelf
      p.auth-subtitle(style="text-align: center; color: #666; margin-bottom: 25px; font-size: 0.95rem;") Acesse sua estante e gerencie suas leituras
      
      form#form-login.auth-form(novalidate)
        .form-group(style="margin-bottom: 15px;")
          label(for="login" style="display: block; margin-bottom: 5px; font-weight: bold; color: #34495e;") Usuário / Login:
          input#login(type="text" name="login" required placeholder="Seu nome de usuário" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;")
        
        .form-group(style="margin-bottom: 25px;")
          label(for="senha" style="display: block; margin-bottom: 5px; font-weight: bold; color: #34495e;") Senha:
          input#senha(type="password" name="senha" required placeholder="Digite sua senha" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;")
        
        button#btn-submeter(type="submit" style="width: 100%; padding: 12px; font-weight: bold; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;") Entrar
        
      .auth-footer(style="text-align: center; margin-top: 20px; font-size: 0.9rem; border-top: 1px solid #eee; padding-top: 15px;")
        p(style="margin: 0; color: #555;") Não tem uma conta? #[a(href="/register" style="color: #007bff; text-decoration: none; font-weight: bold;") Cadastre-se aqui]

  script.
    document.getElementById('form-login').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (typeof window.limparErroGlobal === 'function') {
        window.limparErroGlobal();
      }

      const botao = document.getElementById('btn-submeter');
      botao.innerText = 'Carregando...';
      botao.disabled = true;

      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());

      try {
        const respostaRaw = await fetch('/api/users/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });

        const resultado = await respostaRaw.json().catch(() => ({}));

        // Se a requisição falhar (status 400, 401, etc.)
        if (!respostaRaw.ok) {
          // Captura estritamente a chave 'message' unificada do seu backend
          const mensagemErro = resultado.message || 'Erro ao processar o login.';

          if (window.mostrarErroGlobal) {
            window.mostrarErroGlobal(mensagemErro);
          }
          
          botao.innerText = 'Entrar';
          botao.disabled = false;
          return;
        }

        // Fluxo de Sucesso
        const dadosToken = resultado.dados?.token || resultado.token || resultado.dados || null;
        
        if (dadosToken) {
          const tokenStr = dadosToken.token || resultado.token || (typeof dadosToken === 'string' ? dadosToken : '');
          const papelStr = dadosToken.papel || resultado.papel || 'usuario';
          const idStr = dadosToken.id || resultado.id || '';

          localStorage.setItem('token', tokenStr);
          localStorage.setItem('papel', papelStr);
          localStorage.setItem('id', idStr);
          
          window.location.href = '/';
        } else {
          window.mostrarErroGlobal('O formato de resposta da API de Login está incompatível.');
          botao.innerText = 'Entrar';
          botao.disabled = false;
        }

      } catch (erro) {
        console.error('Erro no script de login:', erro);
        window.mostrarErroGlobal('Não foi possível conectar ao servidor.');
        botao.innerText = 'Entrar';
        botao.disabled = false;
      }
    });
