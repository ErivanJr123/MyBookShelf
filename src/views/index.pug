extends layout

block content
  div(style="text-align: center; padding: 50px 0;")
    h1 📚 MyBookShelf
    
    #msg-erro(style="display: none; background: #ffcccc; color: #cc0000; border: 1px solid #cc0000; padding: 15px; margin: 20px auto; border-radius: 8px; max-width: 400px;")
      strong ⚠️ Atenção: 
      span#texto-erro 

    div(style="display: flex; justify-content: center; gap: 20px; margin-top: 30px;")
      a.btn.btn-primary(href="/authors") ✍️ Autores
      a#link-livros.btn.btn-primary(href="/books") 📖 Livros

  script.
    const btnLivros = document.getElementById('link-livros');
    const msgErro = document.getElementById('msg-erro');
    const textoErro = document.getElementById('texto-erro');

    btnLivros.addEventListener('click', async (e) => {
      e.preventDefault();

      try {
        const response = await fetch('/api/authors');
        const authors = await response.json();

        if (!authors || authors.length === 0) {
          textoErro.innerText = "Cadastre ao menos um autor antes de gerenciar os livros.";
          msgErro.style.display = 'block';
          
          msgErro.style.animation = "shake 0.5s";
          setTimeout(() => msgErro.style.animation = "", 500);
        } else {
          window.location.href = '/books';
        }
      } catch (error) {
        textoErro.innerText = "Erro ao conectar com o servidor.";
        msgErro.style.display = 'block';
      }
    });
