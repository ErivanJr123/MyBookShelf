doctype html
html(lang="pt-br")
  head
    title MyBookShelf
    link(rel="stylesheet", href="/css/style.css")
    style.
      @keyframes shake {
        0% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        50% { transform: translateX(10px); }
        75% { transform: translateX(-10px); }
        100% { transform: translateX(0); }
      }
  body
    nav
      a(href="/") 🏠 Home
      a(href="/authors") ✍️ Autores
      a(href="/books") 📚 Livros
      
    .container
      #msg-global-erro(style="display: none; background: #ffcccc; color: #cc0000; border: 1px solid #cc0000; padding: 15px; margin-bottom: 20px; border-radius: 8px;")
      
      block content

    script(src="/js/apiClient.js")
    
    script.
      window.mostrarErroGlobal = function(mensagem) {
        const caixa = document.getElementById('msg-global-erro');
        if (caixa) {
          caixa.innerText = `❌ Erro: ${mensagem}`;
          caixa.style.display = 'block';
          caixa.style.animation = "shake 0.5s";
          setTimeout(() => caixa.style.animation = "", 500);
        }
      };
      
      window.limparErroGlobal = function() {
        const caixa = document.getElementById('msg-global-erro');
        if (caixa) {
          caixa.style.display = 'none';
        }
      };
