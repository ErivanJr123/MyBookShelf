extends layout

block content
  h1#authorName Carregando...
  
  .card(style="background: #eee; padding: 20px; border-radius: 8px; margin-bottom: 20px;")
    p#authorBirth Carregando...
    
    // Campo para atualizar a nacionalidade (PATCH) de forma elegante
    .form-group(style="margin-top: 15px;")
      label(for="authorNat") Nacionalidade (clique para alterar):
      input#authorNat(name="nacionalidade" placeholder="Digite a nacionalidade e aperte Enter ou clique fora")
      small(style="color: #666; display: block; margin-top: 5px;") * Pressione Enter ou mude o foco do campo para salvar automaticamente.
  
  h3 📚 Livros deste Autor
  ul#authorBooks
    // Preenchido via JavaScript

  hr
  form#deleteAuthorForm
    button.btn.btn-danger(type="submit") Excluir Autor

  script.
    const authorId = window.location.pathname.split('/').pop();
    const inputNat = document.querySelector('#authorNat');

    async function loadAuthorData() {
      try {
        // 1. Busca dados do autor
        const resAuth = await fetch(`/api/authors/${authorId}`);
        const author = await resAuth.json();
        
        document.querySelector('#authorName').innerText = `✍️ ${author.nome}`;
        document.querySelector('#authorBirth').innerText = `Ano de Nascimento: ${author.nascimento}`;
        inputNat.value = author.nacionalidade || '';

        // 2. Busca livros e filtra apenas os deste autor
        const resBooks = await fetch('/api/books');
        const allBooks = await resBooks.json();
        const authorBooks = allBooks.filter(b => b.autorID === authorId);
        
        const list = document.querySelector('#authorBooks');
        list.innerHTML = ""; // Limpa a lista
        
        if (authorBooks.length === 0) {
          list.innerHTML = "<li>Nenhum livro cadastrado para este autor.</li>";
        } else {
          authorBooks.forEach(b => {
            list.innerHTML += `<li><strong>${b.titulo}</strong> — Status: ${b.status}</li>`;
          });
        }
      } catch (err) {
        console.error("Erro ao carregar dados:", err);
      }
    }

    // LÓGICA DO PATCH: Atualiza a nacionalidade usando o centralizador de erros
    async function salvarNacionalidade() {
      window.limparErroGlobal();
      const dados = { nacionalidade: inputNat.value.trim() };
      
      // Se a sua API rejeitar a nacionalidade, o centralizador faz a faixa vermelha tremer na tela!
      const resultado = await window.enviarParaAPI(`/api/authors/${authorId}`, dados, 'PATCH');
      
      if (resultado.sucesso) {
        // Exibe um feedback rápido e limpo no console ou um pequeno log
        console.log("Nacionalidade atualizada com sucesso.");
      }
    }

    // Dispara o salvamento se o usuário apertar Enter
    inputNat.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') {
        e.target.blur(); // Tira o foco para disparar o evento change abaixo
      }
    });

    // Dispara o salvamento quando o usuário clica fora do campo (perde o foco)
    inputNat.addEventListener('change', salvarNacionalidade);

    // Lógica para excluir o autor
    document.querySelector('#deleteAuthorForm').onsubmit = async (e) => {
      e.preventDefault();
      window.limparErroGlobal();
      
      if (!confirm("Tem certeza? Um autor só pode ser removido se não houver livros vinculados.")) return;

      try {
        const res = await fetch(`/api/authors/${authorId}`, { method: 'DELETE' });
        
        if (res.ok) {
          window.location.href = '/authors';
        } else {
          const errorJson = await res.json();
          // Usa a notificação do layout mestre para avisar o bloqueio de remoção da API
          window.mostrarErroGlobal(errorJson.message);
        }
      } catch (err) {
        window.mostrarErroGlobal("Erro crítico ao tentar excluir o autor.");
      }
    };

    loadAuthorData();
