extends layout

block content
  h1#bookTitle Carregando...
  p#bookInfo
  
  #acoesContainer(style="display: flex; flex-direction: column; align-items: flex-start; gap: 10px; margin-top: 15px;")
    div
      label(for="statusSelect" style="margin-right: 5px;") Mudar Status:
      select#statusSelect
        option(value="Ler") Ler
        option(value="Lendo") Lendo
        option(value="Lido") Lido
    
    button#btnExcluir(style="background-color: #dc3545; color: white; border: none; padding: 5px 10px; cursor: pointer; border-radius: 4px;") Remover Livro
    
  script.
    const bookId = window.location.pathname.split('/').pop();

    async function loadBook() {
      try {
        const res = await fetch(`/api/books/${bookId}`);
        const book = await res.json();
        document.querySelector('#bookTitle').innerText = book.titulo;
        document.querySelector('#bookInfo').innerText = `Ano: ${book.publicacao}`;
        document.querySelector('#statusSelect').value = book.status;
      } catch (err) {
        console.error("Erro ao carregar detalhes do livro:", err);
      }
    }

    document.querySelector('#statusSelect').onchange = async (e) => {
      window.limparErroGlobal();
      const data = { status: e.target.value };
      
      const resultado = await window.enviarParaAPI(`/api/books/${bookId}`, data, 'PATCH');
      
      if (resultado.sucesso) {
        alert('Status atualizado com sucesso!');
      }
    };

    document.querySelector('#btnExcluir').onclick = async () => {
      window.limparErroGlobal();
      
      const confirmar = confirm("Tem certeza que deseja remover este livro da estante?");
      if (!confirmar) return;

      const resultado = await window.enviarParaAPI(`/api/books/${bookId}`, {}, 'DELETE');
      
      if (resultado.sucesso) {
        alert('Livro removido com sucesso!');
        window.location.href = '/books';
      }
    };

    loadBook();
