extends layout

block content
  .form-wrapper(style="max-width: 500px; margin: 40px auto; padding: 25px; border: 1px solid #ddd; border-radius: 8px; background: #fff; box-shadow: 0 4px 6px rgba(0,0,0,0.05);")
    h2(style="color: #2c3e50; margin-bottom: 20px; text-align: center;") 📚 Editar Livro / Cópias
    p.subtitle(style="color: #666; margin-bottom: 20px; text-align: center; font-size: 0.95rem;") Atualize o título ou a quantidade de exemplares disponíveis.
    
    form#form-edit-book(novalidate)
      .form-group(style="margin-bottom: 15px;")
        label(for="titulo" style="display: block; margin-bottom: 5px; font-weight: bold; color: #34495e;") Título do Livro:
        input#titulo(type="text" name="titulo" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;")
      
      .form-group(style="margin-bottom: 25px;")
        label(for="exemplar" style="display: block; margin-bottom: 5px; font-weight: bold; color: #34495e;") Quantidade de Exemplares / Cópias:
        input#exemplar(type="number" name="exemplar" min="1" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box;")
      
      .form-actions(style="display: flex; gap: 10px; margin-top: 25px;")
        button#btn-salvar-livro(type="submit" style="flex: 1; padding: 12px; font-weight: bold; background-color: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 1rem;") Salvar Alterações
        a.btn.btn-cancel(href="/books" style="padding: 12px 20px; background: #e0e0e0; color: #333; text-decoration: none; border-radius: 4px; font-weight: bold; font-size: 0.9rem; text-align: center;") Cancelar

  script.
    document.addEventListener('DOMContentLoaded', async () => {
      const urlPartes = window.location.pathname.split('/');
      const bookId = urlPartes[urlPartes.length - 1];

      if (!bookId) {
        window.mostrarErroGlobal('ID do livro não identificado na URL.');
        return;
      }

      const resultado = await window.enviarParaAPI(`/api/books/${bookId}`, null, 'GET');
      
      if (resultado) {
        const book = resultado.dados || resultado;
        document.getElementById('titulo').value = book.titulo || '';
        document.getElementById('exemplar').value = book.exemplar || 1;
      } else {
        window.mostrarErroGlobal('Não foi possível carregar os dados do livro.');
      }

      document.getElementById('form-edit-book').addEventListener('submit', async (e) => {
        e.preventDefault();
        if (window.limparErroGlobal) window.limparErroGlobal();

        const botao = document.getElementById('btn-salvar-livro');
        botao.innerText = 'Salvando...';
        botao.disabled = true;

        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        
        if (data.exemplar) data.exemplar = parseInt(data.exemplar, 10);

        const respostaUpdate = await window.enviarParaAPI(`/api/books/${bookId}`, data, 'PATCH');

        if (respostaUpdate && respostaUpdate.sucesso !== false) {
          alert('Livro atualizado com sucesso!');
          window.location.href = '/books';
        } else {
          botao.innerText = 'Salvar Alterações';
          botao.disabled = false;
        }
      });
    });
